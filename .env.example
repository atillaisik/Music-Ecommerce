# Supabase project credentials (anon key — safe to expose, server enforces RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Public canonical site URL — used for sitemap, OG tags, canonical links.
# Production: https://www.aramuzik.com
# Preview/staging: https://staging.arasounds.com
VITE_SITE_URL=https://www.aramuzik.com

# Sentry DSN (optional — front-end error reporting)
VITE_SENTRY_DSN=
